# .env.local.example
# Copy this file to .env.local and fill in your values.
# .env.local is loaded automatically by dev.ps1 — never commit it.
#
# Generate a JWT secret:  openssl rand -base64 64
# Or use any long random string (64+ chars) for local dev.

# ── Required for Google OAuth login ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# ── JWT signing key ───────────────────────────────────────────────────────────
# MUST be overridden in production. For local dev any long string works.
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars-for-production

# ── AI hint providers (all optional — app works without them) ─────────────────
# Groq: free at https://console.groq.com  (14,400 req/day)
GROQ_API_KEY=gsk_your-groq-key-here

# Gemini: free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# OpenAI: paid, used only if Groq + Gemini both fail
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Database (defaults to local MySQL — only set if using a remote DB) ────────
# DATABASE_URL=jdbc:mysql://localhost:3306/devlearn?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=password
